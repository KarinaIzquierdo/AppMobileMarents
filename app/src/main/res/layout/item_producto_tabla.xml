<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Categoría -->
    <TextView
        android:id="@+id/tvCategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Caballero"
        android:textSize="10sp"
        android:textColor="#4B5563"
        android:background="@drawable/bg_category_chip"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        android:gravity="center" />

    <!-- Nombre -->
    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:text="Cool"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:layout_marginStart="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Variaciones (Color y Tallas) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Categoría -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caballero"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Nombre -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.8"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cool"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Variaciones (Color y Tallas) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Negro"
                android:textSize="10sp"
                android:textColor="#374151"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvTallas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T21 (5)"
                android:textSize="9sp"
                android:textColor="#6B7280"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Stock -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="0.7"
            app:cardBackgroundColor="#F0FDF4"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp">
            <TextView
                android:id="@+id/tvStock"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="25"
                android:textColor="#166534"
                android:textSize="12sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Costo -->
        <TextView
            android:id="@+id/tvCosto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="$40.000"
            android:textColor="#374151"
            android:textSize="13sp" />

        <!-- Precio -->
        <TextView
            android:id="@+id/tvPrecio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="$80.000"
            android:textColor="#374151"
            android:textSize="13sp" />

        <!-- Ganancia -->
        <TextView
            android:id="@+id/tvGanancia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="$40.000"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Acciones -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="horizontal"
            android:layout_marginStart="8dp"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_edit"
                app:tint="#3B82F6"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Editar" />
    </LinearLayout>

</LinearLayout>
