<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Categoría -->
    <TextView
        android:id="@+id/tvCategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Caballero"
        android:textSize="10sp"
        android:textColor="#4B5563"
        android:background="@drawable/bg_category_chip"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        android:gravity="center" />

    <!-- Nombre -->
    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:text="Cool"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:layout_marginStart="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Variaciones (Color y Tallas) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Negro"
            android:textSize="10sp"
            android:textColor="#374151"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/tvTallas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T21 (5)"
            android:textSize="9sp"
            android:textColor="#6B7280"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Stock -->
    <TextView
        android:id="@+id/tvStock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:text="25"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:gravity="center"
        android:background="@drawable/bg_stock_chip"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:layout_marginStart="8dp" />

    <!-- Costo -->
    <TextView
        android:id="@+id/tvCosto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="$40k"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:gravity="end"
        android:layout_marginStart="8dp" />

    <!-- Precio -->
    <TextView
        android:id="@+id/tvPrecio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="$80k"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:gravity="end"
        android:layout_marginStart="8dp" />

    <!-- Ganancia -->
    <TextView
        android:id="@+id/tvGanancia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="$40k"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:gravity="end"
        android:layout_marginStart="8dp" />

    <!-- Acciones -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:orientation="horizontal"
        android:layout_marginStart="8dp"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit"
            app:tint="#3B82F6"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Editar" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            app:tint="#EF4444"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Eliminar" />

    </LinearLayout>

</LinearLayout>
